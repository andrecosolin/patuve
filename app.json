{
  "expo": {
    "name": "Patuvê",
    "slug": "patuve",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "patuve",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "android": {
      "package": "com.patuve.app",
      "versionCode": 2,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f22cbf0-ae07-4c56-92da-99c88bd67400"
      }
    },
    "owner": "ellojob"
  }
}

